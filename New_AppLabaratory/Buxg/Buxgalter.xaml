<Window x:Class="New_AppLabaratory.Buxg.Buxgalter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:New_AppLabaratory.Buxg"
        mc:Ignorable="d"
        Title="Лаборатория — Бухгалтерия"
        Height="700" Width="700"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8" FontFamily="Segoe UI" 
        Loaded="Window_Loaded">

    <Grid>
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="#666666"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="15,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="#E2E8F0"/>
                <Style.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style TargetType="ListView">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BorderBrush" Value="#EAEAEA"/>
            </Style>
        </Grid.Resources>

        <Border Background="White" CornerRadius="12" Margin="25" Padding="25">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="15" Opacity="0.15" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30" ClipToBounds="True" Background="#F0F4F8" BorderBrush="#EAEAEA" BorderThickness="1">
                        <Image Source="Бухгалтер.jpeg" Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                        <TextBlock x:Name="Name" Text="Имя Бухгалтера" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,2"/>
                        <TextBlock Text="Отдел бухгалтерии" Foreground="#888888" 
                                   FontWeight="Regular"
                                   FontSize="14"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="Вернуться" Click="Button_Click" 
                            Width="110" Height="35" Background="#6c757d" 
                            Foreground="White" 
                            FontSize="14"
                            BorderThickness="0"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="Просмотреть отчёты" 
                            Background="#0078D7" Foreground="White" FontWeight="SemiBold"
                            Margin="0,0,12,0" Padding="20,0"/>

                    <Button Content="Отчёт страховой компании" 
                            Background="#28A745" Foreground="White" FontWeight="SemiBold"
                            Padding="20,0"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Сформированные отчеты" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                        <ListView x:Name="ReportsList" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="№ Отчета" Width="100" DisplayMemberBinding="{Binding ReportID}"/>
                                    <GridViewColumn Header="Дата формирования" Width="220" DisplayMemberBinding="{Binding Date}"/>
                                    <GridViewColumn Header="Сумма (₽)" Width="180" DisplayMemberBinding="{Binding Amount}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>