<Window x:Class="AppLaboratory.Labs.Laborant.Biomaterial.CreateBarcode"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppLaboratory.Labs.Laborant.Biomaterial"
        mc:Ignorable="d"
        Title="CreateBarcode" Height="324" Background="#FF76E581"  Width="712">
    <Grid>
        <Image x:Name="BarcodeImg" HorizontalAlignment="Left" Height="213" Margin="432,64,0,0" VerticalAlignment="Top" Width="260"/>
        <Label Content="Штрих-код" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="528,38,0,0"/>
        <Label Content="Код" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="62,63,0,0"/>
        <TextBox x:Name="CodeForCreate" HorizontalAlignment="Left" Height="23" Margin="103,64,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="219"/>
        <Label Content="Генерация штрих-кода" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" FontSize="16"/>
        <Button x:Name="CreateBar" Content="Создать" HorizontalAlignment="Left" Margin="103,154,0,0" VerticalAlignment="Top" Width="219" Click="CreateBar_Click"/>
        <Label Content="Биоматериал" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,92,0,0"/>
        <Button Content="Вернуться к заказу" HorizontalAlignment="Left" Margin="103,179,0,0" VerticalAlignment="Top" Width="219" Click="Button_Click"/>
        <TextBox x:Name="Biomaterial" HorizontalAlignment="Left" Margin="103,96,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="219"/>

    </Grid>
</Window>
