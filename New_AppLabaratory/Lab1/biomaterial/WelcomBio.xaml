<Window x:Class="AppLaboratory.Labs.WelcomeBio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppLaboratory.Labs"
        mc:Ignorable="d"
        Title="Лаборатория — Формирование заказа" 
        MinWidth="580" 
        Background="#F0F4F8" 
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Loaded="Window_Loaded" ContentRendered="Window_ContentRendered">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="25" Padding="25">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="15" Opacity="0.2" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.Resources>
                    <Style TargetType="TextBlock" x:Key="LabelStyle">
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Margin" Value="0,0,0,5"/>
                    </Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="FontWeight" Value="Regular"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,0,0,15"/>
                    </Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="FontWeight" Value="Regular"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,0,0,15"/>
                    </Style>

                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </Grid.Resources>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Формирование заказа" FontSize="24" FontWeight="SemiBold" 
                               Foreground="#333333" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Button Content="Назад" 
                            HorizontalAlignment="Right" Width="80" Height="30"
                            FontSize="14"
                            Background="#6c757d" 
                            Foreground="White" BorderThickness="0" Cursor="Hand" Click="Button_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Код пробирки" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CodeProbirki" Margin="0" 
                                 PreviewTextInput="CodeProbirki_PreviewTextInput"
                                 KeyDown="CodeProbirki_KeyDown"
                                 MaxLength="15"
                                 PreviewLostKeyboardFocus="CodeProbirki_PreviewLostKeyboardFocus"
                                 PreviewMouseDown="CodeProbirki_PreviewMouseDown"/>
                        <TextBlock x:Name="LockIcon" Grid.Column="1" Text="🔓" FontSize="18" 
                                   VerticalAlignment="Center" Margin="10,0,15,0"/>
                        <Button x:Name="GoScanner" 
                                Grid.Column="3" 
                                Content="Сканер" 
                                Width="180" 
                                Height="35" 
                                Background="#28a745" Foreground="White"
                                FontSize="14"
                                BorderThickness="0" Click="GoScanner_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Наименование биоматериала" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="BioName"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <Grid>
                        <TextBlock Text="Пациент" Style="{StaticResource LabelStyle}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AddPacientBD" 
                                   Text="+ Добавить нового"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Right" 
                                   Foreground="#0078D7" 
                                   Cursor="Hand" MouseLeftButtonDown="AddPacientBD_MouseLeftButtonDown"/>
                    </Grid>
                    <ComboBox x:Name="FIOCombo"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,0,0,10">
                    <TextBlock Text="Поиск и добавление услуг" Style="{StaticResource LabelStyle}"/>

                    <Grid Margin="0,0,0,10">
                        <TextBox x:Name="SearchTextBox" 
                                 TextChanged="SearchTextBox_TextChanged"
                                 ToolTip="Начните вводить название или код услуги..."/>

                        <Popup x:Name="SuggestionsPopup" IsOpen="False" StaysOpen="False" PlacementTarget="{Binding ElementName=SearchTextBox}">
                            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" MaxHeight="150" Width="{Binding ActualWidth, ElementName=SearchTextBox}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                                </Border.Effect>
                                <ListBox x:Name="SuggestionsList" BorderThickness="0" 
                                         SelectionChanged="SuggestionsList_SelectionChanged"
                                         Cursor="Hand" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Padding="5,8" FontSize="14"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>

                    <ItemsControl x:Name="SelectedChipsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E1F0FF" CornerRadius="15" Margin="0,0,8,8" Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="#0078D7" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <Button Content="✕" Margin="8,0,0,0" Padding="0" Height="20" Width="20"
                                                Background="Transparent" BorderThickness="0" 
                                                Foreground="#0078D7" FontWeight="Bold" Cursor="Hand"
                                                Click="RemoveChip_Click" Tag="{Binding Code}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <TextBlock Text="Итого к оплате:" FontSize="16" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TotalSumText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#333333"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="AddOrder" Grid.Row="5" Content="Сформировать заказ и распечатать штрих-код" 
                        Height="45" Margin="0,10,0,0" 
                        Background="#0078D7" Foreground="White" FontSize="16" FontWeight="SemiBold" 
                        Cursor="Hand" Click="AddOrder_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="NotificationBorder" Visibility="Collapsed"
                Background="#EE333333" CornerRadius="8" Padding="15,10" 
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
            <TextBlock x:Name="NotificationText" Foreground="White" FontSize="14"/>
        </Border>
    </Grid>
</Window>