<Window x:Class="AppLaboratory.Labs.WelcomeBio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppLaboratory.Labs"
        mc:Ignorable="d"
        Title="Лаборатория — Формирование заказа" 
        SizeToContent="Height" Width="680" 
        Background="#F0F4F8" 
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" ContentRendered="Window_ContentRendered">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="25" Padding="25">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="15" Opacity="0.2" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.Resources>
                    <Style TargetType="TextBlock" x:Key="LabelStyle">
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Margin" Value="0,0,0,5"/>
                    </Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,0,0,15"/>
                    </Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,0,0,15"/>
                    </Style>

                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Style.Resources>
                    </Style>

                </Grid.Resources>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Формирование заказа" FontSize="24" FontWeight="SemiBold" 
                               Foreground="#333333" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Button Content="Назад" 
                            HorizontalAlignment="Right" Width="80" Height="30"
                            FontSize="14"
                            Background="#6c757d" 
                            Foreground="White" BorderThickness="0" Cursor="Hand" Click="Button_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Код пробирки" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CodeProbirki" Margin="0" 
                                 PreviewTextInput="CodeProbirki_PreviewTextInput"
                                 KeyDown="CodeProbirki_KeyDown"
                                 PreviewLostKeyboardFocus="CodeProbirki_PreviewLostKeyboardFocus"
                                 PreviewMouseDown="CodeProbirki_PreviewMouseDown"/>
                        <TextBlock x:Name="LockIcon" Grid.Column="1" Text="🔓" FontSize="18" 
                                   VerticalAlignment="Center" Margin="10,0,15,0"/>
                        <Button x:Name="CreatShtrixCode" Grid.Column="2" Content="Создать Ш-Код" 
                                Width="120" 
                                Height="35" 
                                Margin="0,0,10,0" 
                                Background="#E2E8F0" 
                                BorderThickness="0" 
                                FontSize="12"
                                Click="CreatShtrixCode_Click_1"
                                />
                        <Button x:Name="GoScanner" 
                                Grid.Column="3" 
                                Content="Сканер" 
                                Width="80" 
                                Height="35" 
                                Background="#E2E8F0"
                                FontSize="12"
                                BorderThickness="0" Click="GoScanner_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Наименование биоматериала" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="BioName"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <Grid>
                        <TextBlock Text="Пациент" Style="{StaticResource LabelStyle}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AddPacientBD" 
                                   Text="+ Добавить нового" 
                                   HorizontalAlignment="Right" 
                                   Foreground="#0078D7" 
                                   Cursor="Hand" MouseLeftButtonDown="AddPacientBD_MouseLeftButtonDown"/>
                    </Grid>
                    <ComboBox x:Name="FIOCombo"/>
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Выберите услуги" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ServicesCombo"/>
                </StackPanel>

                <Button x:Name="AddOrder" Grid.Row="5" Content="Сформировать заказ" 
                        Height="45" Margin="0,10,0,0" 
                        Background="#0078D7" Foreground="White" FontSize="16" FontWeight="Bold" 
                        Cursor="Hand" Click="AddOrder_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="NotificationBorder" Visibility="Collapsed"
                Background="#EE333333" CornerRadius="8" Padding="15,10" 
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
            <TextBlock x:Name="NotificationText" Foreground="White" FontSize="14"/>
        </Border>
    </Grid>
</Window>