<Window x:Class="AppLaboratory.Labs.Laborant.Biomaterial.ScannerBarcode"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Лаборатория — Сканер штрих-кода" 
        Height="800" Width="900" 
        Background="#F0F4F8" 
        FontFamily="Segoe UI" 
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="25" Padding="25">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="20" Opacity="0.15" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Height" Value="38"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="Background" Value="#E2E8F0"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Style.Resources>
                    </Style>

                    <Style TargetType="TextBox">
                        <Setter Property="Height" Value="38"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderBrush" Value="#EAEAEA"/>
                        <Setter Property="FontSize" Value="14"/>
                    </Style>

                    <Style TargetType="TextBlock" x:Key="FieldLabel">
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Margin" Value="0,0,0,5"/>
                    </Style>
                </Grid.Resources>

                <TextBlock Grid.Row="0" Text="Сканирование штрих-кода" 
                           FontSize="24" FontWeight="SemiBold" Foreground="#333333"
                           HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Код пробирки" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtBarcodeCode" />
                            <Button Grid.Column="1" x:Name="GetCodeScanner" FontSize="14" Content="Ввод" 
                                    Click="GetCodeScanner_Click" Background="#0078D7" Foreground="White" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Выбор файла" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtFilePath" IsReadOnly="True" Background="#F9F9F9"/>
                            <Button Grid.Column="1" x:Name="Button"  Content="Обзор" 
                                    Click="Button_Click" FontSize="14" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" 
                        Background="#1A202C" 
                        CornerRadius="10" 
                        Padding="2" 
                        ClipToBounds="True"
                        HorizontalAlignment="Center"
                        Width="640" Height="360">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="0"/>
                    </Border.Effect>
                    <wfi:WindowsFormsHost x:Name="CameraHost">
                        <wf:PictureBox x:Name="videoPlayer" Dock="Fill" BackColor="Black" />
                    </wfi:WindowsFormsHost>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                    <Button x:Name="StartCameraButton" Content="Запустить камеру" 
                            Click="StartCameraButton_Click" Width="180" Height="45"
                            Background="#0078D7" Foreground="White" Margin="0,0,15,0"/>

                    <Button x:Name="StopCameraButton" Content="Остановить" 
                            Click="StopCameraButton_Click" Width="180" Height="45"
                            Background="#FEE2E2" Foreground="#DC2626" IsEnabled="False"/>
                </StackPanel>

                <Button x:Name="Back" Grid.Row="4" Content="Назад" Click="Back_Click" 
                        HorizontalAlignment="Right" Width="100" Background="#6c757d" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>