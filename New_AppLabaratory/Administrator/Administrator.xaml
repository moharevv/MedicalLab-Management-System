<Window x:Class="New_AppLabaratory.Administrator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:New_AppLabaratory"
        mc:Ignorable="d"
        Title="Лаборатория - Панель администратора" Height="600" Width="850" 
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8" FontFamily="Segoe UI" Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EAEAEA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    
    

    <Grid>

        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="#666666"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="BorderBrush" Value="#EAEAEA"/>
                <Style.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style TargetType="Button">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="15,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Style.Resources>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>

        <Border Background="White" CornerRadius="12" Margin="20" Padding="25" VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="15" Opacity="0.15" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="30" ClipToBounds="True" Width="60" Height="60" Background="#F0F4F8" BorderBrush="#EAEAEA" BorderThickness="1">
                            <Image Source="Администратор.png" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center" Margin="15,0,0,0">
                            <Label x:Name="Name" Content="Имя Пользователя" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Padding="0"/>
                            <Label Content="Администратор системы" Foreground="#888888" FontSize="14"  Padding="0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="Вернуться" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Width="110" Height="32" Background="#6c757d" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="Button_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="38"/>
                            <Setter Property="Margin" Value="0,0,12,0"/>
                            <Setter Property="Padding" Value="18,0"/>
                            <Setter Property="Background" Value="#0078D7"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Style.Resources>
                        </Style>
                    </StackPanel.Resources>

                    <Button Content="Сформировать отчёт"
                            FontSize="16"/>
                    <Button x:Name="CheckHistoryEntr" 
                            Content="История входа" 
                            Click="CheckHistoryEntr_Click"
                            FontSize="16"/>
                    <Button Content="Работа с данными" 
                            Background="#28a745"
                            FontSize="16"/>
                </StackPanel>

                <Border Grid.Row="2" BorderBrush="#F0F4F8" BorderThickness="1" CornerRadius="8" Background="#FAFAFA">
                    <ListView x:Name="Listik" BorderThickness="0" Background="Transparent" Margin="5">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Пользователь"  Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UserName}" 
                                                       VerticalAlignment="Center" 
                                                       FontWeight="Medium" 
                                                       Foreground="#333333"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Дата и время" Width="190">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Дата входа ↓" 
                                                       Foreground="#0078D7" 
                                                       FontWeight="Bold"
                                                       Cursor="Hand" 
                                                       HorizontalAlignment="Stretch"
                                                       Background="Transparent"
                                                       MouseLeftButtonDown="GridViewColumnHeader_Click"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Date}" Foreground="#666666"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Статус" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,4" 
                                                    Background="#E2E8F0">
                                                <TextBlock Text="{Binding EnterSucces}" HorizontalAlignment="Center" FontSize="12"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>