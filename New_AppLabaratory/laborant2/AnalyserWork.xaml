<Window x:Class="AppLaboratory.Labs.Laborant2.AnalyserWork"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лаборатория — Работа с анализаторами"
        Height="650"
        Width="1100"
        Background="#F0F4F8"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Состояние устройств"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#333333"
                       Margin="0,0,0,20"/>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Анализатор Biorad" Style="{StaticResource SectionHeader}"/>
                    <Button Content="Обновить список"
                            Click="Button_Click"
                            Background="#0078D7"
                            Foreground="White"
                            Margin="0,0,0,15"/>
                    <TextBlock x:Name="StatusBioradText"
                               Text="Статус: ожидание"
                               HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="ProgressBiorad"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Height="10"
                                 Background="#F0F4F8"
                                 Foreground="#0078D7"
                                 BorderThickness="0">
                        <ProgressBar.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </ProgressBar.Resources>
                    </ProgressBar>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Анализатор Ledetect" Style="{StaticResource SectionHeader}"/>
                    <Button Content="Обновить список"
                            Click="Button_Click_1"
                            Background="#28A745"
                            Foreground="White"
                            Margin="0,0,0,15"/>
                    <TextBlock x:Name="StatusLedetectText"
                               Text="Статус: ожидание"
                               HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="ProgressLedetect"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Height="10"
                                 Background="#F0F4F8"
                                 Foreground="#28A745"
                                 BorderThickness="0">
                        <ProgressBar.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </ProgressBar.Resources>
                    </ProgressBar>
                </StackPanel>
            </Border>

            <Button Grid.Row="4"
                    x:Name="BackButton"
                    Content="Назад"
                    Click="BackButton_Click"
                    Background="#6c757d"
                    Foreground="White"
                    Margin="0,20,0,0"/>
        </Grid>

        <Grid Grid.Column="1">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray"
                                      BlurRadius="15"
                                      Opacity="0.15"
                                      ShadowDepth="2"/>
                </Border.Effect>

                <TabControl Background="Transparent" BorderThickness="0">

                    <TabItem Header="Очередь на выполнение">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Доступные исследования"
                                           FontWeight="SemiBold"
                                           FontSize="18"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        x:Name="ToggleMultiSelectButton"
                                        Content="Выбрать несколько услуг"
                                        Click="ToggleMultiSelect_Click"
                                        Background="#FFFFFF"
                                        Foreground="#333333"
                                        BorderBrush="#D0D7DE"
                                        BorderThickness="1"
                                        Padding="10,0"
                                        MinWidth="210"/>
                            </Grid>

                            <Border Grid.Row="1" Background="#FBFBFC" CornerRadius="12" Padding="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="Gray" BlurRadius="10" Opacity="0.08" ShadowDepth="1"/>
                                </Border.Effect>

                                <ListView x:Name="DontServicesList" BorderThickness="0" Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn x:Name="SelectColumn" Header="" Width="0">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Checked="SelectionCheckBox_Changed"
                                                                  Unchecked="SelectionCheckBox_Changed"
                                                                  HorizontalAlignment="Center"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="Заказ" Width="80" DisplayMemberBinding="{Binding OrderId}" />
                                            <GridViewColumn Header="Услуга" Width="200" DisplayMemberBinding="{Binding ServiceName}" />

                                            <GridViewColumn Header="Статус" Width="220">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="{Binding StatusColor}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="Действие" Width="130">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Исследовать"
                                                                Background="#0078D7"
                                                                Foreground="White"
                                                                Padding="5,0"
                                                                Click="SendRow_Click"
                                                                IsEnabled="{Binding CanStart}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>

                            <Button Grid.Row="2"
                                    x:Name="BulkSendButton"
                                    Content="Исследовать выбранные"
                                    Click="BulkSend_Click"
                                    Margin="20,20,20,0"
                                    Height="52"
                                    FontSize="20"
                                    Background="White"
                                    Foreground="#8B1E2D"
                                    BorderBrush="#D0D7DE"
                                    BorderThickness="2"
                                    Visibility="Collapsed"
                                    IsEnabled="False"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="В работе / Результаты">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Текущие исследования"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,10"
                                       FontSize="18"/>

                            <Border Grid.Row="1" Background="#FBFBFC" CornerRadius="12" Padding="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="Gray" BlurRadius="10" Opacity="0.08" ShadowDepth="1"/>
                                </Border.Effect>

                                <ListView x:Name="InProcessList" BorderThickness="0" Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Заказ" Width="80" DisplayMemberBinding="{Binding OrderId}" />

                                            <GridViewColumn Header="Услуга" Width="150" DisplayMemberBinding="{Binding ServiceName}" />

                                            <GridViewColumn Header="Статус" Width="160">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="{Binding StatusColor}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="Результат" Width="120">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ResultValue}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="Действия" Width="220">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Одобрить"
                                                                    Background="#28A745"
                                                                    Foreground="White"
                                                                    Margin="0,0,5,0"
                                                                    Padding="5,0"
                                                                    Click="ApproveRow_Click"
                                                                    Visibility="{Binding ShowApprove, Converter={StaticResource BoolToVis}}"/>

                                                            <Button Content="Отклонить"
                                                                    Background="#DC3545"
                                                                    Foreground="White"
                                                                    Padding="5,0"
                                                                    Click="RejectRow_Click"
                                                                    Visibility="{Binding ShowApprove, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
